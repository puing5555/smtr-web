 },
 {
  "text": "네러티브가 날개를 펴고 있어요. 지금",
  "start": 264.04,
  "duration": 4.04
 },
 {
  "text": "우리가 엄청난 버블에 초입에 있을",
  "start": 266.24,
  "duration": 4.0
 },
 {
  "text": "확률이 높다는 거죠. 버블이 커질수록",
  "start": 268.08,
  "duration": 3.92
 },
 {
  "text": "폭락에 대한 공포도 커질 겁니다.",
  "start": 270.24,
  "duration": 3.72
 },
 {
  "text": "폭락의 타이밍을 재고 준비하고 싶은",
  "start": 272.0,
  "duration": 4.32
 },
 {
  "text": "마음도 커질 거고요. 지금의 AI을",
  "start": 273.96,
  "duration": 4.36
 },
 {
  "text": "다컴 버블에 빚대어서 많이 얘기하지만",
  "start": 276.32,
  "duration": 3.8
 },
 {
  "text": "사실 제가 보기에 요즘은 예전에",
  "start": 278.32,
  "duration": 3.76
 },
 {
  "text": "2001년 다컴버블이나 2008년",
  "start": 280.12,
  "duration": 3.72
 },
 {
  "text": "서브라임 모기지 사태가 있던 그런",
  "start": 282.08,
  "duration": 3.399
 },
 {
  "text": "시대랑은 많이 달라졌습니다.",
  "start": 283.84,
  "duration": 3.84
 },
 {
  "text": "2020년 코로나 폭락도 그렇고 올해",
  "start": 285.479,
  "duration": 4.28
 },
 {
  "text": "2025년 관세 폭락도 그렇고 큰",
  "start": 287.68,
  "duration": 3.799
 },
 {
  "text": "폭락이 와도 불과 두 세 달 안에",
  "start": 289.759,
  "duration": 3.561
 },
 {
  "text": "회복하는 조금 특이한 모습을 보여주고",
  "start": 291.479,
  "duration": 3.761
 },
 {
  "text": "있어요. 20년 코로나 사태는",
  "start": 293.32,
  "duration": 3.719
 },
 {
  "text": "유튜브나 트위터 같은 정보 채널이",
  "start": 295.24,
  "duration": 4.399
 },
 {
  "text": "발달한 이후에 생긴 첫 대폭락이었는데",
  "start": 297.039,
  "duration": 4.321
 },
 {
  "text": "투자에 대한 인사이트랑 전략에 대한",
  "start": 299.639,
  "duration": 3.28
 },
 {
  "text": "정보가 이렇게 빠르게 퍼질 수 있는",
  "start": 301.36,
  "duration": 3.399
 },
 {
  "text": "환경이 어 마련되었다 보니까",
  "start": 302.919,
  "duration": 3.881
 },
 {
  "text": "폭락이라는 너무나 좋은 매수 기회가",
  "start": 304.759,
  "duration": 3.961
 },
 {
  "text": "길게 이어지지 않는 거 같아요. 올해",
  "start": 306.8,
  "duration": 4.04
 },
 {
  "text": "4월에 있었던 관세 폭락도 이제 뭘",
  "start": 308.72,
  "duration": 4.16
 },
 {
  "text": "사도 오르는 너무나 쉽게 부자가 될",
  "start": 310.84,
  "duration": 4.52
 },
 {
  "text": "수 있는 기회였지만 무서울 틈도 없이",
  "start": 312.88,
  "duration": 4.44
 },
 {
  "text": "생각보다 빠르게 끝나 버렸습니다.",
  "start": 315.36,
  "duration": 4.16
 },
 {
  "text": "20년부터 어 주식 시장 폭락이",
  "start": 317.32,
  "duration": 4.319
 },
 {
  "text": "인생을 바꿀 가장 쉬운 기회라는 거를",
  "start": 319.52,
  "duration": 4.36
 },
 {
  "text": "학습한 세대라 그런지 폭락이 생길 만",
  "start": 321.639,
  "duration": 4.321
 },
 {
  "text": "하면은 어 적감 매수하려는 사람들이",
  "start": 323.88,
  "duration": 3.68
 },
 {
  "text": "폭락을 금방 없애 버리는 거 같아요.",
  "start": 325.96,
  "duration": 3.32
 },
 {
  "text": "그동안 상승을 놓치고 보고만 있던",
  "start": 327.56,
  "duration": 3.52
 },
 {
  "text": "사람들이 기회를 틈타 매수를 하기도",
  "start": 329.28,
  "duration": 3.639
 },
 {
  "text": "하고요. 이게 강펀치를 맞더라도",
  "start": 331.08,
  "duration": 3.08
 },
 {
  "text": "회복할 수 있는 시장의 능력이",
  "start": 332.919,
  "duration": 2.961
 },
 {
  "text": "커졌다는 거죠. 저는 아까 말한 두",
  "start": 334.16,
  "duration": 4.159
 },
 {
  "text": "가지 위동성과 네로티브가 존재하는 한",
  "start": 335.88,
  "duration": 4.28
 },
 {
  "text": "이런 회복력은 계속 유지될 거라고",
  "start": 338.319,
  "duration": 4.081
 },
 {
  "text": "믿어요. 그래서 저는 시장의 강펀치를",
  "start": 340.16,
  "duration": 4.319
 },
 {
  "text": "두려워하지 않습니다. 눈을 감지 않고",
  "start": 342.4,
  "duration": 4.48
 },
 {
  "text": "잘 지켜 뜨면서 금리나 사이클과",
  "start": 344.479,
  "duration": 4.321
 },
 {
  "text": "AI와 비트코인 네러티브의 추위만 잘",
  "start": 346.88,
  "duration": 3.439
 },
 {
  "text": "지켜보면서 우리가 잡을 수 있는",
  "start": 348.8,
  "duration": 3.399
 },
 {
  "text": "펀치의 기회, 그런 파멸적 상승을",
  "start": 350.319,
  "duration": 3.88
 },
 {
  "text": "가만히 기다릴 뿐입니다. 언제 올지",
  "start": 352.199,
  "duration": 3.761
 },
 {
  "text": "모르는 폭락이라는 기회를 놓칠까 봐",
  "start": 354.199,
  "duration": 3.84
 },
 {
  "text": "두려워하기보다는 상승을 놓치는 걸",
  "start": 355.96,
  "duration": 4.0
 },
 {
  "text": "두려워해야 된다고 생각합니다. 상승은",
  "start": 358.039,
  "duration": 3.44
 },
 {
  "text": "길고 하락은 점점 짧아지고",
  "start": 359.96,
  "duration": 3.32
 },
 {
  "text": "있으니까요. 그 사이사이에 있는 질환",
  "start": 361.479,
  "duration": 3.201
 },
 {
  "text": "기간을 어떻게 버텨야 되냐라고",
  "start": 363.28,
  "duration": 3.88
 },
 {
  "text": "물으시면 세상학기로 영상을",
  "start": 364.68,
  "duration": 4.28
 },
 {
  "text": "정주행하라고 농담이고요. 그냥 좋은",
  "start": 367.16,
  "duration": 3.96
 },
 {
  "text": "자산에 포지션을 잘 잡아두고 차트",
  "start": 368.96,
  "duration": 4.16
 },
 {
  "text": "대신 현생을 즐기시면 됩니다. 그게",
  "start": 371.12,
  "duration": 3.639
 },
 {
  "text": "스트레스 없이 인생을 바꾸는 장기",
  "start": 373.12,
  "duration": 3.479
 },
 {
  "text": "투자의 포인트니까요. 단기로 가면",
  "start": 374.759,
  "duration": 3.801
 },
 {
  "text": "승률이 50%에 가까워지고 장기로",
  "start": 376.599,
  "duration": 3.841
 },
 {
  "text": "가면 승률이 100%에 가까워집니다.",
  "start": 378.56,
  "duration": 3.44
 },
 {
  "text": "저는 앞으로 우리나라가 금융관국이",
  "start": 380.44,
  "duration": 3.0
 },
 {
  "text": "되어야 먹고 살 수 있다고 생각하는",
  "start": 382.0,
  "duration": 4.08
 },
 {
  "text": "사람으로서 우리 대한민국 투자자들을",
  "start": 383.44,
  "duration": 4.599
 },
 {
  "text": "승률이 100%에 가까워지는 장기",
  "start": 386.08,
  "duration": 3.399
 },
 {
  "text": "투자자들로 전부 바꿔 버릴",
  "start": 388.039,
  "duration": 4.28
 },
 {
  "text": "생각입니다. 이런 세상학기론의 음모에",
  "start": 389.479,
  "duration": 5.241
 },
 {
  "text": "동참하신다면 구독을 눌러 주세요.",
  "start": 392.319,
  "duration": 5.401
 },
 {
  "text": "세상학교이었습니다.",
  "start": 394.72,
  "duration": 3.0
 }
]