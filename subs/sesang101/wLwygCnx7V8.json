 },
 {
  "text": "열려 있다. 이런 생각을 기반으로",
  "start": 264.44,
  "duration": 4.199
 },
 {
  "text": "했던 건데 한마디로 손익비가 너무",
  "start": 266.36,
  "duration": 4.16
 },
 {
  "text": "좋다는 거죠. 뭐 이런 확신을 갖고",
  "start": 268.639,
  "duration": 3.961
 },
 {
  "text": "유튜브 영상도 올리고 주변에도 많이",
  "start": 270.52,
  "duration": 4.0
 },
 {
  "text": "얘기를 했었는데 사실 대부분 그",
  "start": 272.6,
  "duration": 4.28
 },
 {
  "text": "비전에는 어느 정도 공감하면서도 어",
  "start": 274.52,
  "duration": 4.48
 },
 {
  "text": "가격 변동성이 워낙 흉악하다 보니까",
  "start": 276.88,
  "duration": 4.0
 },
 {
  "text": "가격을 기준으로 사고 팔고 거래를",
  "start": 279.0,
  "duration": 3.72
 },
 {
  "text": "하기 시작하고 뭐 단기 하락을",
  "start": 280.88,
  "duration": 4.36
 },
 {
  "text": "예상해서 어 손실을 줄이려고 잠깐",
  "start": 282.72,
  "duration": 4.479
 },
 {
  "text": "시장을 나왔다가 큰 상승을 놓쳐",
  "start": 285.24,
  "duration": 4.28
 },
 {
  "text": "버리거나 아니면은 어 비트코인이",
  "start": 287.199,
  "duration": 4.201
 },
 {
  "text": "단기적으로 크게 상승했을 때 더 큰",
  "start": 289.52,
  "duration": 3.2
 },
 {
  "text": "수익을 먹기 위해서 이제 알트로",
  "start": 291.4,
  "duration": 3.56
 },
 {
  "text": "옮겨갔다가 알트는 더 안 오르고",
  "start": 292.72,
  "duration": 4.8
 },
 {
  "text": "비트는 계속 꾸준히 더 올라가니까 어",
  "start": 294.96,
  "duration": 4.44
 },
 {
  "text": "상승을 놓친 상태로 다시 이제 비트로",
  "start": 297.52,
  "duration": 4.0
 },
 {
  "text": "돌아오기도 하고 그런 다양한 일들을",
  "start": 299.4,
  "duration": 5.2
 },
 {
  "text": "반복하면서 어 비트 가격으로 노르는데",
  "start": 301.52,
  "duration": 4.679
 },
 {
  "text": "돈는 생각보다 많이 못 번 그런",
  "start": 304.6,
  "duration": 3.48
 },
 {
  "text": "사례들을 많이 봤던 거 같아요. 그런",
  "start": 306.199,
  "duration": 4.521
 },
 {
  "text": "일들을 직접 이제 많이 목격하면서 아",
  "start": 308.08,
  "duration": 4.48
 },
 {
  "text": "날씨는 예측하려고 하지 말아야겠다.",
  "start": 310.72,
  "duration": 3.52
 },
 {
  "text": "막 단기적인 날씨 예측을 하면서",
  "start": 312.56,
  "duration": 3.8
 },
 {
  "text": "부지런히 움직여서 투자를 하는 것보다",
  "start": 314.24,
  "duration": 4.079
 },
 {
  "text": "아 그냥 장기적인 흐름인 계절만 보고",
  "start": 316.36,
  "duration": 3.48
 },
 {
  "text": "가만히 있는게 훨씬 더 돈이",
  "start": 318.319,
  "duration": 3.801
 },
 {
  "text": "되는구나. 뭐 이런 투자 원칙들이",
  "start": 319.84,
  "duration": 4.079
 },
 {
  "text": "잡히기 시작한 거 같아요. 그때는 그",
  "start": 322.12,
  "duration": 3.799
 },
 {
  "text": "파티에 개인들만 이렇게 하나 둘씩",
  "start": 323.919,
  "duration": 4.481
 },
 {
  "text": "나타나서 춤을 추는 시대였는데 지금",
  "start": 325.919,
  "duration": 3.801
 },
 {
  "text": "춤을 추고 있는 사람들을 보면",
  "start": 328.4,
  "duration": 3.04
 },
 {
  "text": "기업들이 들어와서 춤을 추고 있는 거",
  "start": 329.72,
  "duration": 3.759
 },
 {
  "text": "같아요. 그리고 아직 개인들은 춤을",
  "start": 331.44,
  "duration": 4.16
 },
 {
  "text": "적극적으로 출지 말지 조심스러워하는",
  "start": 333.479,
  "duration": 4.121
 },
 {
  "text": "거 같습니다. 폭락에 대한 무서운",
  "start": 335.6,
  "duration": 3.76
 },
 {
  "text": "얘기들은 나오는데 그렇다고 가격이",
  "start": 337.6,
  "duration": 4.0
 },
 {
  "text": "떨어지진 않고 비트코인은 전고점을",
  "start": 339.36,
  "duration": 4.2
 },
 {
  "text": "갱신해 가지만 개인들은 아직 살짝",
  "start": 341.6,
  "duration": 3.92
 },
 {
  "text": "소심한 느낌입니다. 코인 시장에서",
  "start": 343.56,
  "duration": 3.639
 },
 {
  "text": "개인의 비중을 조금씩 기관들이",
  "start": 345.52,
  "duration": 3.519
 },
 {
  "text": "갉아먹으면서 흡수해 가는 과정이 있지",
  "start": 347.199,
  "duration": 3.801
 },
 {
  "text": "않을까 좀 생각이 되네요. 뭐 사실",
  "start": 349.039,
  "duration": 3.961
 },
 {
  "text": "개인들이 많이 들어와야 알트코인이나",
  "start": 351.0,
  "duration": 3.68
 },
 {
  "text": "민주식들이 급격히 이렇게 올라가는",
  "start": 353.0,
  "duration": 4.199
 },
 {
  "text": "시장 분위기가 만들어지는데 뭐 지금",
  "start": 354.68,
  "duration": 4.44
 },
 {
  "text": "뭐 알트도 불장이라고는 하지만 아직",
  "start": 357.199,
  "duration": 4.241
 },
 {
  "text": "예전 시장만큼은 좀 못한 거 같아요.",
  "start": 359.12,
  "duration": 4.12
 },
 {
  "text": "그래서 저는 현재 그동안 싸운",
  "start": 361.44,
  "duration": 4.039
 },
 {
  "text": "업면으로나 뭐 컴플라이언스 측면에서",
  "start": 363.24,
  "duration": 4.44
 },
 {
  "text": "기관들이 좋아하는 비트코인과 이더리움",
  "start": 365.479,
  "duration": 4.201
 },
 {
  "text": "위주로 보유하고 있습니다. 기업들의",
  "start": 367.68,
  "duration": 3.84
 },
 {
  "text": "파티는 비트코인 이더리움에서 주로",
  "start": 369.68,
  "duration": 3.88
 },
 {
  "text": "벌어지고 개인들의 파티는 알트에서",
  "start": 371.52,
  "duration": 3.72
 },
 {
  "text": "많이 열리니까요. 기업들의 파티가",
  "start": 373.56,
  "duration": 3.639
 },
 {
  "text": "절정에 다다를 때 그 가격 상승을",
  "start": 375.24,
  "duration": 3.92
 },
 {
  "text": "따라서 개인들의 파티가 이제 시작되기",
  "start": 377.199,
  "duration": 3.84
 },
 {
  "text": "시작하고 개인들의 파티가 절정에",
  "start": 379.16,
  "duration": 3.68
 },
 {
  "text": "다다르면 또 한 번 큰 폭락의",
  "start": 381.039,
  "duration": 3.841
 },
 {
  "text": "리스크가 다가온다는 뜻일 겁니다.",
  "start": 382.84,
  "duration": 4.04
 },
 {
  "text": "기업은 웬만하면 지속 가능한 수준으로",
  "start": 384.88,
  "duration": 4.159
 },
 {
  "text": "춤을 추지만 개인들의 파티는 때때로",
  "start": 386.88,
  "duration": 3.96
 },
 {
  "text": "지속 불가능한 형태로 걷잡을 수 없이",
  "start": 389.039,
  "duration": 3.16
 },
 {
  "text": "커지기도 하니까요. 저는 요즘",
  "start": 390.84,
  "duration": 3.68
 },
 {
  "text": "비트코인을 볼 때 제가 가진 모든",
  "start": 392.199,
  "duration": 4.201
 },
 {
  "text": "돈을 쏟아보었던 그 5년 전만큼은",
  "start": 394.52,
  "duration": 4.079
 },
 {
  "text": "아니지만 그래도 아직 손익비가 좋다고",
  "start": 396.4,
  "duration": 3.96
 },
 {
  "text": "생각합니다. 아직이 파티에 추가로",
  "start": 398.599,
  "duration": 3.16
 },
 {
  "text": "합류할 기업들도 많이 남아 있다고",
  "start": 400.36,
  "duration": 3.52
 },
 {
  "text": "생각하고 미국이랑 중국도 아직 정부",
  "start": 401.759,
  "duration": 3.921
 },
 {
  "text": "차원에서 대규모 매집을 실시하진",
  "start": 403.88,
  "duration": 4.0
 },
 {
  "text": "않았으니까요. 벌써 비트코인의 시총은",
  "start": 405.68,
  "duration": 5.12
 },
 {
  "text": "금까지 따라왔고 열배만 오르면 금",
  "start": 407.88,
  "duration": 4.64
 },
 {
  "text": "시총을 넘어서는 일이 생길 겁니다.",
  "start": 410.8,
  "duration": 3.72
 },
 {
  "text": "저는 금의 상방과 하방을 생각한",
  "start": 412.52,
  "duration": 4.399
 },
 {
  "text": "손익비랑 비트코인의 상방과 하방을",
  "start": 414.52,
  "duration": 4.32
 },
 {
  "text": "생각한 손익비를 볼 때 비트코인이",
  "start": 416.919,
  "duration": 3.361
 },
 {
  "text": "금을 제치는 건 시간 문제라고",
  "start": 418.84,
  "duration": 3.44
 },
 {
  "text": "생각해요. 그게 내년이 될지 5년",
  "start": 420.28,
  "duration": 4.08
 },
 {
  "text": "후가 될지 10년 후가 될지 전혀",
  "start": 422.28,
  "duration": 3.96
 },
 {
  "text": "모르겠지만 그리고 제가 완전히 틀릴",
  "start": 424.36,
  "duration": 4.2
 },
 {
  "text": "수도 있지만 어 비트코인은 여전히",
  "start": 426.24,
  "duration": 4.76
 },
 {
  "text": "진지하게 포트폴리오의 큰 비중을 할해",
  "start": 428.56,
  "duration": 4.039
 },
 {
  "text": "볼 만한 손익비 좋은 자산이라고",
  "start": 431.0,
  "duration": 4.12
 },
 {
  "text": "생각합니다. 비트코인을 처음 봤을 때",
  "start": 432.599,
  "duration": 4.72
 },
 {
  "text": "저는 비트코인은 사기라는 선입견을",
  "start": 435.12,
  "duration": 4.04
 },
 {
  "text": "벗어나는 미래를 그렸습니다. 그리고",
  "start": 437.319,
  "duration": 3.921
 },
 {
  "text": "2020년에 저는 비트코인을 수많은",
  "start": 439.16,
  "duration": 3.64
 },
 {
  "text": "상장사들이 받아들이는 미래를",
  "start": 441.24,
  "duration": 4.16
 },
 {
  "text": "그렸어요. 그리고 지금의 전는 수많은",
  "start": 442.8,
  "duration": 4.959
 },
 {
  "text": "개인 투자자들과 자산운용사, 일반",
  "start": 445.4,
  "duration": 4.639
 },
 {
  "text": "기업, 각국 정부까지 비트코인을",
  "start": 447.759,
  "duration": 4.72
 },
 {
  "text": "금처럼 당연하게 포트폴리오에 포함하는",
  "start": 450.039,
  "duration": 4.121
 },
 {
  "text": "그런 미래를 그리고 있습니다.",
  "start": 452.479,
  "duration": 3.921
 },
 {
  "text": "지금처럼 트럼프가 연준을 흔들면서",
  "start": 454.16,
  "duration": 3.759
 },
 {
  "text": "돈을 풀어내려고 하는 시기. 뭐",
  "start": 456.4,
  "duration": 3.479
 },
 {
  "text": "미국만의 얘기는 아니지만 화폐 가치가",
  "start": 457.919,
  "duration": 3.96
 },
 {
  "text": "이렇게 점점 빠르게 증발하는 시기에",
  "start": 459.879,
  "duration": 3.961
 },
 {
  "text": "공격을 위한 투자가 아니더라도 나의",
  "start": 461.879,
  "duration": 3.6
 },
 {
  "text": "자산 가치 방어를 위해서라도",
  "start": 463.84,
  "duration": 3.359
 },
 {
  "text": "비트코인을 진지하게 생각해야 된다고",
  "start": 465.479,
  "duration": 3.12
 },
 {
  "text": "생각합니다. 비트코인의 미래를",
  "start": 467.199,
  "duration": 3.361
 },
 {
  "text": "그리면서 비트코인의 성장을 봤던",
  "start": 468.599,
  "duration": 3.72
 },
 {
  "text": "7년이 넘는 시간 동안 비트코인은 뭐",
  "start": 470.56,
  "duration": 3.28
 },
 {
  "text": "상승을 더 이상 안 할 것처럼 이제",
  "start": 472.319,
  "duration": 3.641
 },
 {
  "text": "떨어지기도 하고 이렇게 올라가도 되나",
  "start": 473.84,
  "duration": 4.44
 },
 {
  "text": "싶을만큼 올라가기도 했어요. 미래에",
  "start": 475.96,
  "duration": 4.12
 },
 {
  "text": "대한 확신이 아무리 강하더라도 사실",
  "start": 478.28,
  "duration": 3.68
 },
 {
  "text": "실전에서 그 가격 변동을 버티는 거는",
  "start": 480.08,
  "duration": 3.48
 },
 {
  "text": "또 다른 문제더라고요. 저는 이제",
  "start": 481.96,
  "duration": 3.519
 },
 {
  "text": "비트코인은 변동성이 극도로 심했던",
  "start": 483.56,
  "duration": 3.88
 },
 {
  "text": "시기는 어느 정도 지나간 거 같다는",
  "start": 485.479,
  "duration": 4.041
 },
 {
  "text": "생각입니다. 제 생각이니까 당연히",
  "start": 487.44,
  "duration": 3.599
 },
 {
  "text": "틀릴 수 있지만요. 어 기관이",
  "start": 489.52,
  "duration": 3.239
 },
 {
  "text": "들어오고 이해 관계자가 많아지기",
  "start": 491.039,
  "duration": 3.84
 },
 {
  "text": "시작하는 2025년 비트코인은",
  "start": 492.759,
  "duration": 4.321
 },
 {
  "text": "트럼프의 관세 쇼크를 거치면서 미국",
  "start": 494.879,
  "duration": 4.361
 },
 {
  "text": "주식보다도 하락을 덜하는 그런 좀",
  "start": 497.08,
  "duration": 4.0
 },
 {
  "text": "좋은 가격 안정성을 보여주는 그런",
  "start": 499.24,
  "duration": 3.519
 },
 {
  "text": "업력을 쌓았다고 생각합니다. 이런",
  "start": 501.08,
  "duration": 3.799
 },
 {
  "text": "비트코인이 금 왕주화를 노리러 가는",
  "start": 502.759,
  "duration": 4.201
 },
 {
  "text": "그런 여정 속에서 앞으로 남은 가격",
  "start": 504.879,
  "duration": 3.921
 },
 {
  "text": "번동은 과연 버티실 수 있을지",
  "start": 506.96,
  "duration": 3.6
 },
 {
  "text": "그래프만 한번 유심히 보시면서",
  "start": 508.8,
  "duration": 3.679
 },
 {
  "text": "시뮬레이션 해 보세요. 지금까지는",
  "start": 510.56,
  "duration": 4.24
 },
 {
  "text": "재벌진 막내 아들 진도준처럼 미래를",
  "start": 512.479,
  "duration": 3.881
 },
 {
  "text": "아는 투자자라고 생각하고 그래프를",
  "start": 514.8,
  "duration": 3.799
 },
 {
  "text": "봐오셨다면 이번엔 내가 미래에 대한",
  "start": 516.36,
  "duration": 4.0
 },
 {
  "text": "확신이 없는 비트코인에 대해서 잘",
  "start": 518.599,
  "duration": 3.56
 },
 {
  "text": "모르는 투자자라고 생각하고 변동을",
  "start": 520.36,
  "duration": 3.32
 },
 {
  "text": "다시 봐 보세요. 버틸 수 있을 것",
  "start": 522.159,
  "duration": 3.401
