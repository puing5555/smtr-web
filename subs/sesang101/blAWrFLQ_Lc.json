  "text": "이런 생각을 좀 하게 되지 않나요 또",
  "start": 274.009,
  "duration": 4.231
 },
 {
  "text": "학교 선배 중에는 이제 기부 쪽으로는",
  "start": 275.96,
  "duration": 5.25
 },
 {
  "text": "제가 좀 롤모델로 삼고 있는 김정오",
  "start": 278.24,
  "duration": 5.31
 },
 {
  "text": "대표님이 계시는데 어 베터 네이버",
  "start": 281.21,
  "duration": 4.53
 },
 {
  "text": "창립 멤버이자 사회적기업의 털을",
  "start": 283.55,
  "duration": 3.42
 },
 {
  "text": "운영하고 계시고",
  "start": 285.74,
  "duration": 3.929
 },
 {
  "text": "이제 그 분이 학교에 27년 인가",
  "start": 286.97,
  "duration": 4.259
 },
 {
  "text": "이제 꾸준히 이제 기부금을 늘려 오신",
  "start": 289.669,
  "duration": 4.291
 },
 {
  "text": "걸 보고 아 머시따 나도 꾸준히 점점",
  "start": 291.229,
  "duration": 4.981
 },
 {
  "text": "이렇게 늘려가면서 기부를 해야 겠단",
  "start": 293.96,
  "duration": 3.929
 },
 {
  "text": "생각을 좀 하게 되거든 그래서 이",
  "start": 296.21,
  "duration": 3.269
 },
 {
  "text": "영상을 통해서 여러분들도 좀",
  "start": 297.889,
  "duration": 3.661
 },
 {
  "text": "소액이라도 기부를 좀씩 해보고 그걸",
  "start": 299.479,
  "duration": 4.951
 },
 {
  "text": "조용히 뭐 숨기지 말고 집요한 에",
  "start": 301.55,
  "duration": 4.95
 },
 {
  "text": "널리 알리어 없었으면 해요 메세나",
  "start": 304.43,
  "duration": 3.539
 },
 {
  "text": "세법 맛있는거 먹었다고 올리듯이",
  "start": 306.5,
  "duration": 3.81
 },
 {
  "text": "기부한 걸 이제 올리는 거죠 기부한",
  "start": 307.969,
  "duration": 3.931
 },
 {
  "text": "게 창피한 건 아니잖아요 뭐 제가",
  "start": 310.31,
  "duration": 3.329
 },
 {
  "text": "방금 뭐 젊을 때 기부를 하는게",
  "start": 311.9,
  "duration": 3.93
 },
 {
  "text": "가성비가 좋다고 하긴 했지만 사실",
  "start": 313.639,
  "duration": 3.9
 },
 {
  "text": "그건 제가 바꿔보고 싶은 분위기도",
  "start": 315.83,
  "duration": 3.66
 },
 {
  "text": "학원 젊었을 때 기부 하더라도",
  "start": 317.539,
  "duration": 4.711
 },
 {
  "text": "신기하게 보지 않는 뭐 잼은 사람들이",
  "start": 319.49,
  "duration": 4.44
 },
 {
  "text": "오히려 더 기부를 많이 하는 그런",
  "start": 322.25,
  "duration": 3.66
 },
 {
  "text": "움직임을 만들고 싶어서",
  "start": 323.93,
  "duration": 4.05
 },
 {
  "text": "어 여러분들께도 이제 기부라는 취미를",
  "start": 325.91,
  "duration": 4.47
 },
 {
  "text": "억 추천 드리고 싶고 좀 한살이라도",
  "start": 327.98,
  "duration": 4.14
 },
 {
  "text": "어릴때 기회를 좀 시작해 보셨으면",
  "start": 330.38,
  "duration": 2.64
 },
 {
  "text": "좋겠습니다",
  "start": 332.12,
  "duration": 4.05
 },
 {
  "text": "분명히 다른 치밀 과는 색다른 재미를",
  "start": 333.02,
  "duration": 5.34
 },
 {
  "text": "천재 되시지 않을까 하는 생각이 들고",
  "start": 336.17,
  "duration": 4.29
 },
 {
  "text": "기부 에 대해서는 점차 이제 기부를",
  "start": 338.36,
  "duration": 4.2
 },
 {
  "text": "더 많이 해 가면서 영상으로 더",
  "start": 340.46,
  "duration": 4.29
 },
 {
  "text": "말씀을 드려 보도록 하겠습니다",
  "start": 342.56,
  "duration": 3.63
 },
 {
  "text": "오늘까지 입니다",
  "start": 344.75,
  "duration": 4.1
 },
 {
  "text": "회사개요 겠습니다",
  "start": 346.19,
  "duration": 2.66
 }
]