 },
 {
  "text": "기대 이상",
  "start": 341.69,
  "duration": 3.0
 },
 {
  "text": "결과적으로 기대를 하면서 했을 때",
  "start": 343.04,
  "duration": 3.57
 },
 {
  "text": "보다도 좋은 결과를 얻으실 수 있을",
  "start": 344.69,
  "duration": 3.9
 },
 {
  "text": "거라고 생각을 합니다 저는 생각이나",
  "start": 346.61,
  "duration": 4.14
 },
 {
  "text": "아이디어의 가치는 0 이라고 생각을",
  "start": 348.59,
  "duration": 4.14
 },
 {
  "text": "해요 제로에 가깝다고 생각을 합니다",
  "start": 350.75,
  "duration": 4.41
 },
 {
  "text": "그냥 생각만으로 남는다면 그걸 이제",
  "start": 352.73,
  "duration": 5.04
 },
 {
  "text": "말이나 글로 표현 하거나 아니면",
  "start": 355.16,
  "duration": 4.8
 },
 {
  "text": "실제로 현실에서 구현해 낼 때 비로소",
  "start": 357.77,
