 {
  "text": "오는 건물 투명성이 확실히 뭐",
  "start": 271.599,
  "duration": 4.351
 },
 {
  "text": "리스크가 되게 됩니다 그 태도가 터치",
  "start": 273.97,
  "duration": 3.419
 },
 {
  "text": "거다 터질 거 다 그래서 가장 재산",
