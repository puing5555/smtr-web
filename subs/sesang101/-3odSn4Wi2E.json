 },
 {
  "text": "그동안 이제 국부 펀드라고 할 만한게",
  "start": 257.759,
  "duration": 3.76
 },
 {
  "text": "없었거든요.이 이 무역 흑자국들이",
  "start": 259.359,
  "duration": 4.4
 },
 {
  "text": "미국의 채권과 주식을 매입하고 달러",
  "start": 261.519,
  "duration": 4.041
 },
 {
  "text": "보유액 축적을 통해서 이제 약세를",
  "start": 263.759,
  "duration": 4.361
 },
 {
  "text": "유지하듯이 미국도이 펀드를 통해서",
  "start": 265.56,
  "duration": 4.8
 },
 {
  "text": "외국의 국차나 이제 주식과 같은 해외",
  "start": 268.12,
  "duration": 4.56
 },
 {
  "text": "자산을 매입하고 다른 나라의 화폐를",
  "start": 270.36,
  "duration": 4.44
 },
 {
  "text": "절상시키는 그런 전략을 취하지 않을까",
  "start": 272.68,
  "duration": 4.48
 },
 {
  "text": "싶어요. 지금까지 미국은 다른 나라의",
  "start": 274.8,
  "duration": 4.04
 },
 {
  "text": "이런 외환 개입 전략을 환율",
  "start": 277.16,
  "duration": 3.759
 },
 {
  "text": "조작이라고 규정하고 규제하는 선에서",
  "start": 278.84,
  "duration": 4.76
 },
 {
  "text": "그치고 본인들이 이런 정책을 똑같이",
  "start": 280.919,
  "duration": 5.161
 },
 {
  "text": "사용하진 않았었는데 트럼프는 오케이",
  "start": 283.6,
  "duration": 4.4
 },
 {
  "text": "환율 조작 우리도 똑같이 한다. 무역",
  "start": 286.08,
  "duration": 3.88
 },
 {
  "text": "주지 불균형을 조지려면 무역 수지",
  "start": 288.0,
  "duration": 3.6
 },
 {
  "text": "쪽이 아니라 자본 수지 쪽을 조야",
  "start": 289.96,
  "duration": 3.2
 },
 {
  "text": "되는구나. 이런 생각까지 간 거죠.",
  "start": 291.6,
  "duration": 3.159
 },
 {
  "text": "지금 우리는 이런 과정을 보고 있는게",
  "start": 293.16,
  "duration": 3.28
 },
 {
  "text": "아닌가 싶어요. 뭐 저번 영상에서도",
  "start": 294.759,
  "duration": 3.641
 },
 {
  "text": "말씀드렸듯이 트럼프는 무욕 불교량을",
  "start": 296.44,
  "duration": 4.16
 },
 {
  "text": "해결하고 싶어하긴 하지만 동시에",
  "start": 298.4,
  "duration": 4.32
 },
 {
  "text": "미국의 부채도 같이 해결해야 됩니다.",
  "start": 300.6,
  "duration": 4.24
 },
 {
  "text": "트럼프는 이리저리 머리를 굴리고",
  "start": 302.72,
  "duration": 4.24
 },
 {
  "text": "미국의 힘을 활용해서 높은 관세를",
  "start": 304.84,
  "duration": 4.48
 },
 {
  "text": "때리면서도 금리는 낮추고 싶어요.",
  "start": 306.96,
  "duration": 4.04
 },
 {
  "text": "하지만 당연히 쉽지 않겠죠.",
  "start": 309.32,
  "duration": 3.64
 },
 {
  "text": "인플레이션을 잡아야 하는 의무를 가진",
  "start": 311.0,
  "duration": 4.199
 },
 {
  "text": "연주는 이제 트럼프 말을 들어 주지도",
  "start": 312.96,
  "duration": 4.079
 },
 {
  "text": "않을 거고요. 현실적으로 둘 중",
  "start": 315.199,
  "duration": 3.601
 },
 {
  "text": "하나만 골라야 되는 상황입니다. 무역",
  "start": 317.039,
  "duration": 4.121
 },
 {
  "text": "불균형 해결과 미국의 부채 해결 금리",
  "start": 318.8,
  "duration": 3.959
 },
 {
  "text": "인하. 그리고 돌아가는 꼴을 보면",
  "start": 321.16,
  "duration": 3.56
 },
 {
  "text": "트럼프가 의도했든 의도하지 않았든",
  "start": 322.759,
  "duration": 3.72
 },
 {
  "text": "이제 금리를 포기하고 있는 모양세로",
  "start": 324.72,
  "duration": 3.599
 },
 {
  "text": "보이고요. 이번 3월 인플레이션율",
  "start": 326.479,
  "duration": 3.641
 },
 {
  "text": "데이터를 보면은 2.8%에서",
  "start": 328.319,
  "duration": 4.521
 },
 {
  "text": "2.4%로 내려왔습니다. 연준의 타겟",
  "start": 330.12,
  "duration": 5.24
 },
 {
  "text": "2%에 더 가까워진 건데 4월 초에",
  "start": 332.84,
  "duration": 4.24
 },
 {
  "text": "괜히 트럼프가 관세를 더 붙이지",
  "start": 335.36,
  "duration": 4.16
 },
 {
  "text": "않았더라면 이제 금리가 알아서 내려갈",
  "start": 337.08,
  "duration": 4.36
 },
 {
  "text": "수도 있었던 상황인 거죠. 그런데",
  "start": 339.52,
  "duration": 3.6
 },
 {
  "text": "4월 2일부터 트럼프까지 이제 관세",
  "start": 341.44,
  "duration": 4.199
 },
 {
  "text": "폭탄을 던지기 시작하더니 국제 금리가",
  "start": 343.12,
  "duration": 5.12
 },
 {
  "text": "3.9%에서 4.5%까지 다시 폭등해",
  "start": 345.639,
  "duration": 4.56
 },
 {
  "text": "버렸어요. 미국 국채에 대한 매력도가",
  "start": 348.24,
  "duration": 3.88
 },
 {
  "text": "떨어져서 더 높은 금리를 줘야만",
  "start": 350.199,
  "duration": 3.56
 },
 {
  "text": "한다는 얘기입니다. 가만히 있었으면",
  "start": 352.12,
  "duration": 3.6
 },
 {
  "text": "원하는 대로 금리가 내려갔을 텐데",
  "start": 353.759,
  "duration": 3.801
 },
 {
  "text": "괜히 관세 전쟁을 시작해서 금리를",
  "start": 355.72,
  "duration": 3.759
 },
 {
  "text": "올려버린 꼴이죠. 만약 이걸 트럼프가",
  "start": 357.56,
  "duration": 4.4
 },
 {
  "text": "의도했다라는 시나리오라면은 국체 미국",
  "start": 359.479,
  "duration": 4.481
 },
 {
  "text": "투자 자산에 대한 매력도를 줄여서이",
  "start": 361.96,
  "duration": 3.76
 },
 {
  "text": "자본 흑자 유입을 좀 줄이려고",
  "start": 363.96,
  "duration": 4.28
 },
 {
  "text": "했다라면 금리보다는 무역 불균형",
  "start": 365.72,
  "duration": 4.36
 },
 {
  "text": "해소와 제조업 부흥에 더 높은 우선",
  "start": 368.24,
  "duration": 3.56
 },
 {
  "text": "순위를 두고 있다라고 이해하면 될",
  "start": 370.08,
  "duration": 3.76
 },
 {
  "text": "거고요. 만약 트럼프가 왕청에서",
  "start": 371.8,
  "duration": 4.64
 },
 {
  "text": "삽질를 했다라는 시나리오라면은 자신의",
  "start": 373.84,
  "duration": 4.96
 },
 {
  "text": "잘못을 인정하고 모든 관세 전쟁을",
  "start": 376.44,
  "duration": 4.4
 },
 {
  "text": "철패하고 이제 인플레이션을 잡는데",
  "start": 378.8,
  "duration": 5.36
 },
 {
  "text": "연준과 힘을 합치면 좋겠지만 트럼프의",
  "start": 380.84,
  "duration": 7.16
 },
 {
  "text": "성격상 그걸 인정할까요?",
  "start": 384.16,
  "duration": 5.36
 },
 {
  "text": "오히려 이왕 이렇게 된 거 무역",
  "start": 388.0,
  "duration": 3.599
 },
 {
  "text": "불균형 해소에 올인할 가능성도 있을",
  "start": 389.52,
  "duration": 4.88
 },
 {
  "text": "것 같습니다. 둘 중 어떻게 되든 둘",
  "start": 391.599,
  "duration": 4.72
 },
 {
  "text": "중 어떤 시나리오이든 트럼프는 본인의",
  "start": 394.4,
  "duration": 3.84
 },
 {
  "text": "임기 동안 이런 지속적인 무역 불균형",
  "start": 396.319,
  "duration": 3.841
 },
 {
  "text": "구조를 해소하기 위한 다양한 수단을",
  "start": 398.24,
  "duration": 3.44
 },
 {
  "text": "활용할 가능성이 높을 겁니다. 그니까",
  "start": 400.16,
  "duration": 3.439
 },
 {
  "text": "외국의 달러가 달러 금융 자산으로",
  "start": 401.68,
  "duration": 4.04
 },
 {
  "text": "입되는 걸 막기 위해서 외국인들이",
  "start": 403.599,
  "duration": 4.841
 },
 {
  "text": "미국 주식이나 이자로 얻는 수익에 큰",
  "start": 405.72,
  "duration": 4.199
 },
 {
  "text": "세금을 때려 버릴지도 모르고요.",
  "start": 408.44,
  "duration": 3.64
 },
 {
  "text": "1985년 플라자 합의처럼 달러",
  "start": 409.919,
  "duration": 3.68
 },
 {
  "text": "가치를 인위적으로 내리기 위해서",
  "start": 412.08,
  "duration": 3.28
 },
 {
  "text": "주변국들과 환율 조정 합의를",
  "start": 413.599,
  "duration": 3.201
 },
 {
  "text": "이끌어내고자 할 수도 있습니다.",
  "start": 415.36,
  "duration": 3.279
 },
 {
  "text": "그때랑은 달리 이제 중국이라는 대안도",
  "start": 416.8,
  "duration": 3.72
 },
 {
  "text": "있고 주변국들이 쉽게 협상 테이블에",
  "start": 418.639,
  "duration": 3.24
 },
 {
  "text": "앉으려고 하지 않겠지만 일대일",
  "start": 420.52,
  "duration": 3.48
 },
 {
  "text": "관세로이 총들고 협박하듯이 주변국들을",
  "start": 421.879,
  "duration": 3.88
 },
 {
  "text": "하나하나 협박해서 테이블에 앉치게",
  "start": 424.0,
  "duration": 4.16
 },
 {
  "text": "하겠죠. 결과적으로 1944년 브레트",
  "start": 425.759,
  "duration": 4.28
 },
 {
  "text": "체제 때와 같이 지난 50년간의",
  "start": 428.16,
  "duration": 3.64
 },
 {
  "text": "법칙을 완전히 바꿔 버리는 그런",
  "start": 430.039,
  "duration": 3.401
 },
 {
  "text": "완전히 다른 질서의 시작이 될 수도",
  "start": 431.8,
  "duration": 3.2
 },
 {
  "text": "있어요. 아니면 이미 돌이킬 수 없는",
  "start": 433.44,
  "duration": 3.479
 },
 {
  "text": "선을 넘었을지도 모릅니다. 이제 금융",
  "start": 435.0,
  "duration": 4.039
 },
 {
  "text": "투자는 미국에 하는게 진리였던 시대가",
  "start": 436.919,
  "duration": 3.68
 },
 {
  "text": "끝나 버릴지도 모르죠. 혹시 여러분은",
  "start": 439.039,
  "duration": 3.401
 },
 {
  "text": "어떻게 생각하시나요? 5에서 10년에",
  "start": 440.599,
  "duration": 3.28
 },
 {
  "text": "한 번는 기회로 그치고 이대로",
  "start": 442.44,
  "duration": 3.439
 },
 {
  "text": "반등하면서 올라갈 수도 있고 미국의",
  "start": 443.879,
  "duration": 3.481
 },
 {
  "text": "신용 등급이 2년 만에 한 번 더",
  "start": 445.879,
  "duration": 3.561
 },
 {
  "text": "강등되고 미국 시장에 대한 신뢰도가",
  "start": 447.36,
  "duration": 3.76
 },
 {
  "text": "더 떨어지면서 여기서 또 반토막이",
  "start": 449.44,
  "duration": 3.24
 },
 {
  "text": "날지도 모릅니다. 무역 의존도를",
  "start": 451.12,
  "duration": 3.479
 },
 {
  "text": "줄이는 미국과 중국이 전쟁을 준비하는",
  "start": 452.68,
  "duration": 3.6
 },
 {
  "text": "걸지도 모르고요. 돈은 통화 가치가",
  "start": 454.599,
  "duration": 3.121
 },
 {
  "text": "강한 곳으로 흐르다 보니까 달러",
  "start": 456.28,
  "duration": 3.68
 },
 {
  "text": "가치가 떨어지면 일본 증시나 국장이",
  "start": 457.72,
  "duration": 3.96
 },
 {
  "text": "한동안 이제 미장 수익률을 이기게 될",
  "start": 459.96,
  "duration": 3.32
 },
 {
  "text": "수도 있고요. 미국 자산의 매력도가",
  "start": 461.68,
  "duration": 3.28
 },
 {
  "text": "낮아지는 시기가 가상자산 시장에",
  "start": 463.28,
  "duration": 3.16
 },
 {
  "text": "기회가 될지도 모릅니다. 수많은",
  "start": 464.96,
  "duration": 3.079
 },
 {
  "text": "사람들이 확신을 갖고 각자 다양한",
  "start": 466.44,
  "duration": 3.24
 },
 {
  "text": "얘기를 하지만 제가 확신하는 유일한",
  "start": 468.039,
  "duration": 3.321
 },
 {
  "text": "건 미래를 진짜 알고 있는 사람은",
  "start": 469.68,
  "duration": 3.239
 },
 {
  "text": "아무도 없다는 겁니다. 단지 미래에",
  "start": 471.36,
  "duration": 3.44
 },
 {
  "text": "적응하기에 최적이라고 생각하는 전략을",
  "start": 472.919,
  "duration": 3.521
 },
 {
  "text": "밀고 나갈 뿐이죠. 오늘 영상은",
  "start": 474.8,
  "duration": 3.6
 },
 {
  "text": "여기까지입니다. 들어주셔서",
  "start": 476.44,
  "duration": 6.28
 },
 {
  "text": "감사합니다. 대상 기원이었습니다.",
  "start": 478.4,
  "duration": 4.32
 }
]