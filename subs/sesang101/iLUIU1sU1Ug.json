 },
 {
  "text": "CEO의 말이 좀 하나씩 실현되고",
  "start": 561.32,
  "duration": 3.4
 },
 {
  "text": "있는 느낌이에요. 아토도 이제",
  "start": 563.12,
  "duration": 3.04
 },
 {
  "text": "트럼프가 원하는 대로 이제 우주",
